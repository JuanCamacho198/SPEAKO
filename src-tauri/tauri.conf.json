{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Speako",
  "version": "1.3.0",
  "identifier": "com.juan-camacho.speako",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Speako",
        "width": 380,
        "height": 420,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": true,
        "center": true,
        "transparent": true,
        "shadow": true
      }
    ],
    "trayIcon": null,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/JuanCamacho198/SPEAKO/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2RDMwNkI2NUQ0ODUwNDIKUldSQ1VFaGR0Z2JUNXJTYUpSK2ZGRGlvV3hIeHRTMDcwT0Joa3puK3BsOHhHYkx3OU1kSlB0WU4K"
    }
  }
}
